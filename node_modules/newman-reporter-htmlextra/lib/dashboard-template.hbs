                                            <i class="float-lg-right fa fa-chevron-down" style="padding-top: 5px;"></i>
                                        </a>
                                    </div>
                                    <div id="folder-collapse-{{parent.id}}-iteration-{{parent.iteration}}" class="collapse" aria-labelledby="folder-{{parent.id}}">
                                        {{> aggregations}}
                                    </div>
                                {{else}}
                                    {{> aggregations}}
                                {{/if}}
                                {{/isNotIn}}
                            {{/each}}
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>


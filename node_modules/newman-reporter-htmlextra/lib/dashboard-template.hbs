<!DOCTYPE html>
<html lang="en" style="overflow-y: scroll;">
<head>
  <meta charset="UTF-8">
  <title>{{browserTitle}}</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.13.0/css/all.min.css">
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.1.3/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/10.1.2/styles/default.min.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs4/dt-1.10.18/datatables.min.css"/>

<style>
:root {
    --radius-sm: 8px;
    --radius-md: 14px;
    --radius-lg: 18px;
    --shadow-sm: 0 4px 12px rgba(15, 23, 42, 0.08);
    --shadow-md: 0 10px 30px rgba(15, 23, 42, 0.12);
    --transition: all .25s ease;
}

code.renderMarkdown table,
code.renderMarkdown th,
code.renderMarkdown td {
    border: 1px solid rgba(148, 163, 184, 0.35);
    width: max-content;
    padding: .75rem;
    border-collapse: collapse;
}

.theme-dark {
    --background-color: #0f172a;
    --background-gradient: linear-gradient(180deg, #0f172a 0%, #111827 100%);
    --surface: #111827;
    --surface-soft: #1f2937;
    --surface-muted: #273449;
    --bg-card-deck: transparent;
    --text-color: #e5edf6;
    --muted-text: #9fb0c3;
    --tab-border: solid 1px rgba(148, 163, 184, 0.18);
    --success: #22c55e;
    --success-soft: #173a2b;
    --failure: #ef4444;
    --failure-soft: #3f1d24;
    --warning: #f59e0b;
    --warning-soft: #423018;
    --info: #3b82f6;
    --info-soft: #1b3358;
    --badge-outline: #93c5fd;
    --badge-bg: #e2e8f0;
    --badge-text: #0f172a;
    --failure-row: rgba(239, 68, 68, 0.16);
    --warning-row: rgba(245, 158, 11, 0.16);
    --card-bg: #111827;
    --card-footer: #0b1220;
    --form-input: #0f172a;
    --form-border: rgba(148, 163, 184, 0.22);
    --hov-text: #ffffff;
    --h4-text: #f8fafc;
    --link: #93c5fd;
    --table-head: #1f2937;
    --table-border: rgba(148, 163, 184, 0.15);
}

.theme-light {
    --background-color: #f8fafc;
    --background-gradient: linear-gradient(180deg, #f8fafc 0%, #eef4fb 100%);
    --surface: #ffffff;
    --surface-soft: #f8fafc;
    --surface-muted: #eef2f7;
    --bg-card-deck: transparent;
    --text-color: #0f172a;
    --muted-text: #64748b;
    --tab-border: solid 1px rgba(15, 23, 42, 0.08);
    --success: #16a34a;
    --success-soft: #dcfce7;
    --failure: #dc2626;
    --failure-soft: #fee2e2;
    --warning: #d97706;
    --warning-soft: #fef3c7;
    --info: #2563eb;
    --info-soft: #dbeafe;
    --badge-outline: #1d4ed8;
    --badge-bg: #e2e8f0;
    --badge-text: #0f172a;
    --failure-row: #fee2e2;
    --warning-row: #fef3c7;
    --card-bg: #ffffff;
    --card-footer: #f8fafc;
    --form-input: #ffffff;
    --form-border: rgba(15, 23, 42, 0.12);
    --hov-text: #ffffff;
    --h4-text: #0f172a;
    --link: #1d4ed8;
    --table-head: #f1f5f9;
    --table-border: rgba(15, 23, 42, 0.08);
}

html, body {
  height: 100%;
}

body {
  padding-top: 26px;
  background: var(--background-gradient) !important;
  color: var(--text-color);
  font-family: "Inter", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  letter-spacing: 0.1px;
}

a { color: var(--link); }
a:hover { text-decoration: none; opacity: 0.92; }

h1, h2, h3, h4, h5, h6 {
    color: var(--h4-text);
    font-weight: 700;
}

hr { border-top: 1px solid var(--table-border); }

.container { max-width: 1440px; }

#execution-data {
  padding: 18px;
  border: var(--tab-border);
  border-top: none;
  background: var(--surface);
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.nav-tabs,
.single-line-tabs {
  padding-top: 10px;
  overflow-y: auto;
}

.nav-tabs { min-height: 88px; }
.single-line-tabs { min-height: 58px; }

.card {
  overflow: hidden;
  border: 1px solid var(--table-border) !important;
  border-radius: var(--radius-lg) !important;
  background: var(--card-bg);
  box-shadow: var(--shadow-sm);
}

.card-header {
    border-bottom: 1px solid var(--table-border);
    padding: 1rem 1.25rem;
    background-color: var(--surface-soft);
}

.card-body {
    background-color: var(--card-bg);
    padding: 1.25rem;
}

.card-footer {
    padding: .85rem 1.25rem;
    background-color: var(--card-footer);
    border-top: 1px solid var(--table-border);
}

.card-deck { background-color: var(--bg-card-deck) !important; }

.form-control {
    background: var(--form-input);
    border: 1px solid var(--form-border);
    color: var(--text-color);
    border-radius: var(--radius-sm);
}

.form-control:focus {
    background: var(--form-input);
    color: var(--text-color);
    border-color: rgba(59, 130, 246, 0.45);
    box-shadow: 0 0 0 0.18rem rgba(59, 130, 246, 0.12);
}

.custom-tab {
  padding: 10px 16px;
  margin-right: 8px;
  height: 46px;
  min-width: 60px;
  text-align: center;
  border: var(--tab-border);
  border-bottom: none;
  cursor: pointer;
  border-radius: 12px 12px 0 0;
  font-weight: 700;
  transition: var(--transition);
  box-shadow: var(--shadow-sm);
}

.custom-tab:hover { transform: translateY(-1px); }

.text-white { color: #ffffff !important; }

body.theme-dark .hljs {
    background: #0b1220 !important;
    color: #dbe4ee !important;
    border-radius: var(--radius-sm);
}

.bg-info { background: linear-gradient(135deg, var(--info) 0%, #60a5fa 100%) !important; }
.bg-success { background: linear-gradient(135deg, var(--success) 0%, #4ade80 100%) !important; }
.bg-warning { background: linear-gradient(135deg, var(--warning) 0%, #fbbf24 100%) !important; }
.bg-danger { background: linear-gradient(135deg, var(--failure) 0%, #f87171 100%) !important; }

.alert {
    border: none;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
}

.alert-success { background-color: var(--success-soft) !important; color: var(--text-color) !important; }
.alert-warning { background-color: var(--warning-soft) !important; color: var(--text-color) !important; }
.alert-info { background-color: var(--info-soft) !important; color: var(--text-color) !important; }
.alert-danger { background-color: var(--failure-soft) !important; color: var(--text-color) !important; }

body.theme-dark .alert-dark {
    background-color: #1f2937 !important;
    color: #e5edf6 !important;
}

.badge {
    border-radius: 999px;
    font-weight: 700;
    padding: 0.4em 0.75em;
}

.badge-light {
    color: var(--badge-text) !important;
    background-color: var(--badge-bg) !important;
}

.badge-warning {
    color: #111827 !important;
    background-color: #facc15 !important;
}

.table-warning>td { background-color: var(--warning-row); }
.table-danger>td { background-color: var(--failure-row); }

body.theme-dark .table .thead-light th,
body.theme-light .table .thead-light th {
    background-color: var(--table-head) !important;
    border-color: var(--table-border) !important;
    color: var(--text-color) !important;
}

.table {
    color: var(--text-color);
    background: transparent;
}

.table td, .table th {
    border-color: var(--table-border) !important;
    vertical-align: middle;
}

.table-hover tbody tr:hover {
    background-color: rgba(148, 163, 184, 0.08);
}

.itPassed {
  background: linear-gradient(135deg, #22c55e 0%, #4ade80 100%);
  color: white;
}
.itFailed {
  background: linear-gradient(135deg, #ef4444 0%, #f87171 100%);
  color: white;
}

.resultsInfoPass { color: var(--success); padding-top: 4px; }
.resultsInfoFail { color: var(--failure); padding-top: 4px; }

.badge-outline-success {
  color: var(--success);
  border: 1px solid rgba(34, 197, 94, 0.45);
  background-color: transparent;
}

.badge-outline {
  color: var(--badge-outline);
  border: 1px solid rgba(147, 197, 253, 0.45);
  background-color: transparent;
}

.btn {
    border-radius: 999px;
    font-weight: 700;
    transition: var(--transition);
}

.btn-outline-success {
    color: var(--success) !important;
    border-color: rgba(34, 197, 94, 0.5) !important;
    background: transparent !important;
}

.backToTop:hover,
.btn-outline-success:hover {
  background-color: var(--success) !important;
  border-color: var(--success) !important;
  color: var(--hov-text) !important;
}

.btn-outline-secondary {
  background-color: var(--info) !important;
  border-color: var(--info) !important;
  color: #fff !important;
}

.btn-outline-secondary:hover { filter: brightness(1.05); }

.card-body .rotate {
  z-index: 1;
  float: right;
  height: 100%;
}

.card-body .rotate i {
  color: rgba(255, 255, 255, 0.14);
  position: absolute;
  right: -10px;
  bottom: -6px;
  display: block;
  transform: rotate(-22deg);
}

.dyn-height {
  max-height: 350px;
  overflow-y: auto;
}

.nav-pills .nav-link.active {
  background-color: transparent !important;
}

.nav-pills .nav-link {
  font-weight: 700;
}

.backToTop {
  display: none;
  position: fixed;
  bottom: 14px;
  right: 20px;
  z-index: 99;
  font-size: 14px;
  outline: none;
  cursor: pointer;
  padding: 12px 16px;
  border-radius: 999px;
  box-shadow: var(--shadow-md);
}

.card-header .fa {
  transition: .25s transform ease-in-out;
}
.card-header .collapsed .fa {
  transform: rotate(90deg);
}

::-webkit-scrollbar {
  width: 7px;
  height: 7px;
}

::-webkit-scrollbar-track {
  background: rgba(148, 163, 184, 0.14);
  border-radius: 999px;
}

::-webkit-scrollbar-thumb {
  background: rgba(100, 116, 139, 0.8);
  border-radius: 999px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(71, 85, 105, 0.95);
}

.switch {
  position: relative;
  display: inline-block;
  width: 50px;
  height: 24px;
  margin: 0 8px;
  vertical-align: middle;
}

.switch input {
  opacity: 0;
  width: 0;
  height: 0;
}

.slider {
  position: absolute;
  cursor: pointer;
  inset: 0;
  background-color: #cbd5e1;
  transition: 0.4s;
}

.slider:before {
  position: absolute;
  content: "";
  height: 18px;
  width: 18px;
  left: 3px;
  top: 3px;
  transition: 0.4s;
  box-shadow: 0 4px 10px rgba(15, 23, 42, 0.18);
  background: white;
}

input:checked + .slider {
  background-color: var(--info);
}

input:focus + .slider {
  box-shadow: 0 0 1px var(--info);
}

input:checked + .slider:before {
  transform: translateX(26px);
}

.slider.round { border-radius: 999px; }
.slider.round:before { border-radius: 50%; }

table.dataTable td, table.dataTable tr { vertical-align: middle; }

body.theme-dark code { color: #e2e8f0 !important; }
body.theme-light code { color: #0f172a !important; }

.text-wrap {
    word-wrap: break-word;
    min-width: 600px;
    max-width: 600px;
    white-space: normal;
}

.top-toolbar {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
    margin-bottom: 16px;
    color: var(--muted-text);
    font-weight: 600;
}

.summary-shell { margin-bottom: 20px; }
.summary-title { letter-spacing: 0.3px; margin-bottom: 6px; }
.summary-subtitle { color: var(--muted-text); margin-bottom: 24px; }

.kpi-card .card-body { border-radius: var(--radius-lg); }

.kpi-card h6 {
    font-size: 0.78rem;
    letter-spacing: .08em;
    opacity: .92;
}

.kpi-card h1 { margin-bottom: 0; }

.section-title {
    border-radius: 12px;
    padding: 10px 14px;
    margin-bottom: 16px;
    font-size: 0.95rem;
    letter-spacing: .06em;
}

.table-responsive, pre, code { border-radius: var(--radius-sm); }
pre { margin-bottom: 0; }
nav.table-responsive { padding-bottom: 6px; }

#iterationSelected {
    color: var(--muted-text) !important;
    font-weight: 700;
}

.theme-toggle-label {
    color: var(--muted-text);
    font-weight: 700;
}

.tab-pane { padding-top: 6px; }
.main > .row:first-of-type { margin-bottom: 6px; }

.border-info { border-color: var(--table-border) !important; }
.border-danger { border-color: rgba(239, 68, 68, 0.35) !important; }
.border-warning { border-color: rgba(245, 158, 11, 0.35) !important; }

@media (max-width: 768px) {
    .text-wrap {
        min-width: 100%;
        max-width: 100%;
    }

    .top-toolbar {
        justify-content: center;
    }
}
</style>
</head>
<body class="theme-dark">

<script>
function setTheme(themeName) {
    localStorage.setItem('theme', themeName);
    document.body.className = themeName;
}

function toggleTheme() {
    if (localStorage.getItem('theme') === 'theme-light') {
        setTheme('theme-dark');
    } else {
        setTheme('theme-light');
    }
}
</script>

<div class="container">
    <div class="top-toolbar">
        <span class="theme-toggle-label">Light</span>
        <label id="switch" class="switch">
            <input type="checkbox" onchange="toggleTheme()" id="slider">
            <span class="slider round"></span>
        </label>
        <span class="theme-toggle-label">Dark</span>
    </div>

    <div class="card summary-shell">
        <div class="card-header">
            {{#with summary}}
            <ul class="nav nav-pills mb-0 nav-justified" id="pills-tab" role="tablist">
                <li class="nav-item bg-info">
                    <a class="nav-link active text-white" id="pills-summary-tab" data-toggle="pill" href="#pills-summary" role="tab" aria-controls="pills-summary" aria-selected="true">Summary</a>
                </li>
                <li class="nav-item bg-success">
                    <a class="nav-link text-white" id="pills-requests-tab" data-toggle="pill" href="#pills-requests" role="tab" aria-controls="pills-requests" aria-selected="false">Requests <span class="badge badge-light">{{stats.requests.total}}</span></a>
                </li>
                <li class="nav-item bg-danger">
                    <a class="nav-link text-white" id="pills-failed-tab" data-toggle="pill" href="#pills-failed" role="tab" aria-controls="pills-failed" aria-selected="false">Failed <span class="badge badge-light">{{failures.length}}</span></a>
                </li>
                <li class="nav-item bg-warning">
                    <a class="nav-link text-white" id="pills-skipped-tab" data-toggle="pill" href="#pills-skipped" role="tab" aria-controls="pills-skipped" aria-selected="false">Skipped <span class="badge badge-light">{{#gt skippedTests.length 0}}{{skippedTests.length}}{{else}}0{{/gt}}</span></a>
                </li>
            </ul>
            {{/with}}
        </div>

        <div class="card-body p-0">
            <div class="tab-content" id="pills-tabContent">

                <div class="tab-pane fade show active" id="pills-summary" role="tabpanel" aria-labelledby="pills-summary-tab">
                    <div class="p-4">
                        <div class="row">
                            <div class="col-md-9 col-lg-12 main">
                                <h1 class="display-{{titleSize}} text-center summary-title">{{title}}</h1>
                                <h5 class="text-center summary-subtitle">{{timestamp}}</h5>

                                {{#with summary}}
                                <div class="row">
                                    <div class="col-lg-3 col-md-6 mb-3">
                                        <div class="card text-white kpi-card">
                                            <div class="card-body {{#gt failures.length 0}}bg-danger{{else}}bg-success{{/gt}}">
                                                <div class="rotate"><i class="fa fa-retweet fa-5x"></i></div>
                                                <h6 class="text-uppercase">Total Iterations</h6>
                                                <h1 class="display-{{#gt stats.assertions.total 999 }}4{{else}}1{{/gt}}">{{stats.iterations.total}}</h1>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-lg-3 col-md-6 mb-3">
                                        <div class="card text-white kpi-card">
                                            <div class="card-body bg-info">
                                                <div class="rotate"><i class="fa fa-list fa-4x"></i></div>
                                                <h6 class="text-uppercase">Total Assertions</h6>
                                                <h1 class="display-{{#gt stats.assertions.total 999 }}4{{else}}1{{/gt}}">{{totalTests stats.assertions.total skippedTests.length}}</h1>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-lg-3 col-md-6 mb-3">
                                        <div class="card text-white kpi-card">
                                            <div class="card-body {{#gt failures.length 0}}bg-danger{{else}}bg-success{{/gt}}">
                                                <div class="rotate"><i class="fa fa-plus-circle fa-5x"></i></div>
                                                <h6 class="text-uppercase">Failed Tests</h6>
                                                <h1 class="display-{{#gt stats.assertions.total 999 }}4{{else}}1{{/gt}}">{{failures.length}}</h1>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-lg-3 col-md-6 mb-3">
                                        <div class="card text-white kpi-card">
                                            <div class="card-body {{#gt skippedTests.length 0}}bg-warning{{else}}bg-success{{/gt}}">
                                                <div class="rotate"><i class="fa fa-share fa-5x"></i></div>
                                                <h6 class="text-uppercase">Skipped Tests</h6>
                                                <h1 class="display-{{#gt stats.assertions.total 999 }}4{{else}}1{{/gt}}">{{#gt skippedTests.length 0}}{{skippedTests.length}}{{else}}0{{/gt}}</h1>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <hr>

                                <div class="row">
                                    <div class="col">
                                        <div class="row">
                                            <div class="col-sm-12 mb-3">
                                                <div class="card border-info">
                                                    <div class="card-body">
                                                        <h5 class="card-title text-uppercase text-white text-center bg-info section-title">File Information</h5>
                                                        <span><i class="fas fa-file-code"></i></span><strong> Collection:</strong> {{collection.name}}<br>
                                                        {{#if folders}}<span><i class="fas fa-folder"></i></span><strong> Specified Folders:</strong> {{folders}}<br>{{/if}}
                                                        {{#if environment.name}}<span><i class="fas fa-file-code"></i></span><strong> Environment:</strong> {{environment.name}}<br>{{/if}}
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        {{#if @root.showGlobalData}}
                                        {{#if globals.values.members.length}}
                                        <div class="row">
                                            <div class="col-sm-12 mb-3">
                                                <div class="card-deck">
                                                    <div class="card border-info" style="width: 50rem;">
                                                        <h5 class="card-header bg-info text-center text-uppercase">
                                                            <a data-toggle="collapse" href="#global-values" aria-expanded="true" aria-controls="collapse-example" id="global-heading" class="env-heading collapsed d-block">
                                                                <i class="float-lg-right fa fa-chevron-down"></i>
                                                                Global Variables
                                                            </a>
                                                        </h5>
                                                        <div id="global-values" class="collapse" aria-labelledby="global-heading">
                                                            <div class="card-body">
                                                                <div class="table-responsive dyn-height">
                                                                    <table class="table table-bordered">
                                                                        <thead class="thead-light text-center">
                                                                            <tr><th>Variable Name</th><th>Variable Value</th></tr>
                                                                        </thead>
                                                                        <tbody>
                                                                            {{#each globals.values.members}}
                                                                            {{#isNotIn key @root.skipGlobalVars}}
                                                                            <tr>
                                                                                <td class="text-nowrap">{{key}}</td>
                                                                                <td>{{value}}</td>
                                                                            </tr>
                                                                            {{/isNotIn}}
                                                                            {{/each}}
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        {{/if}}
                                        {{/if}}

                                        {{#if @root.showEnvironmentData}}
                                        {{#if environment.values.members.length}}
                                        <div class="row">
                                            <div class="col-sm-12 mb-3">
                                                <div class="card-deck">
                                                    <div class="card border-info" style="width: 50rem;">
                                                        <h5 class="card-header bg-info text-center text-uppercase">
                                                            <a data-toggle="collapse" href="#environment-values" aria-expanded="true" aria-controls="collapse-example" id="environment-heading" class="env-heading collapsed d-block">
                                                                <i class="float-lg-right fa fa-chevron-down"></i>
                                                                Environment Variables
                                                            </a>
                                                        </h5>
                                                        <div id="environment-values" class="collapse" aria-labelledby="environment-heading">
                                                            <div class="card-body">
                                                                <div class="table-responsive dyn-height">
                                                                    <table class="table table-bordered">
                                                                        <thead class="thead-light text-center">
                                                                            <tr><th>Variable Name</th><th>Variable Value</th></tr>
                                                                        </thead>
                                                                        <tbody>
                                                                            {{#each environment.values.members}}
                                                                            {{#isNotIn key @root.skipEnvironmentVars}}
                                                                            <tr>
                                                                                <td class="text-nowrap">{{key}}</td>
                                                                                <td>{{value}}</td>
                                                                            </tr>
                                                                            {{/isNotIn}}
                                                                            {{/each}}
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        {{/if}}
                                        {{/if}}

                                        {{#if collection.description}}
                                        <div class="row">
                                            <div class="col-sm-12 mb-3">
                                                <div class="card border-info">
                                                    <div class="card-body">
                                                        <h5 class="card-title text-uppercase text-white text-center bg-info section-title">Collection Description</h5>
                                                        <div class="dyn-height">
                                                            <code class="renderMarkdown">{{collection.description}}</code>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
